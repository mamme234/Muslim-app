# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/muslimapp

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Client URL (for CORS)
CLIENT_URL=http://localhost:5500,http://127.0.0.1:5500

# API Keys
ALADHAN_API_URL=https://api.aladhan.com/v1
QURAN_API_URL=https://api.alquran.cloud/v1

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=uploads/
